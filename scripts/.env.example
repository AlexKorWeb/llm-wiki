# Copy this file to scripts/.env and fill in the values.
# scripts/.env is gitignored — never commit it.
# Скопируй этот файл в scripts/.env и заполни значения.
# scripts/.env в .gitignore — не коммить его.

# Bot token from @BotFather
# Токен бота от @BotFather
BOT_TOKEN=123456789:AA-your-telegram-bot-token-here

# Your Telegram numeric user ID — get it from @userinfobot
# Твой числовой Telegram user ID — узнать через @userinfobot
OWNER_USER_ID=000000000

# Seconds of inactivity before INGEST starts after the last forwarded post
# Задержка перед запуском INGEST после последнего поста (секунды)
DEBOUNCE_SECONDS=60

# Max agent turns per `claude -p` ingest run (optional, default 60)
# Лимит ходов агента на один прогон `claude -p` (опционально, по умолчанию 60)
CLAUDE_MAX_TURNS=60
